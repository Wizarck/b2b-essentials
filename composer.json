{
  "name": "wizarck/b2b-essentials",
  "description": "B2B essentials for WooCommerce: roles, moderated registration, hidden pricing, NIF/VIES validation",
  "type": "wordpress-plugin",
  "license": "LGPL-3.0-or-later",
  "require": {
    "php": ">=8.1"
  },
  "require-dev": {
    "phpunit/phpunit": "^10",
    "squizlabs/php_codesniffer": "^3.9",
    "wp-coding-standards/wpcs": "^3.0"
  },
  "autoload": {
    "psr-4": {
      "B2bEssentials\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "B2bEssentials\\Tests\\": "tests/"
    }
  }
}
